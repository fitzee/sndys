DEFINITION MODULE Tonnetz;
(* Tonal centroid features -- map chroma to tonnetz space.
   Produces 6 dimensions encoding fifths, minor thirds,
   and major thirds relationships. *)

(* ComputeTonnetz -- map a 12-element chroma vector to 6 tonnetz dimensions.
   tonnetz must have at least 6 elements.
   Dimensions:
     [0] = fifths y     (sin(i * pi/2))
     [1] = fifths x     (cos(i * pi/2))
     [2] = minor 3rds y (sin(i * 2*pi/3))
     [3] = minor 3rds x (cos(i * 2*pi/3))
     [4] = major 3rds y (sin(i * 7*pi/6))
     [5] = major 3rds x (cos(i * 7*pi/6))  *)
PROCEDURE ComputeTonnetz(chroma: ARRAY OF LONGREAL;
                          VAR tonnetz: ARRAY OF LONGREAL);

END Tonnetz.
